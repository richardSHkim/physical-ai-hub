# ── GR00T 환경변수 (.env.gr00t) ───────────────

# Inference 서버
GR00T_PORT=8001
GR00T_CKPT=

# Training
GR00T_DATASET_PATH=datasets/richardshkim/piper_banana_v2_v2.1
GR00T_RUN_NAME=gr00t_n_1d6_piper
GR00T_OUTPUT_DIR=outputs/Isaac-GR00T
GR00T_MODALITY_CONFIG_PATH=vla/gr00t/tools/piper_modality_config.py
GR00T_BASE_MODEL=nvidia/GR00T-N1.6-3B
GR00T_NUM_GPUS=1
GR00T_MAX_STEPS=2000
GR00T_SAVE_STEPS=2000
GR00T_GLOBAL_BATCH_SIZE=32
