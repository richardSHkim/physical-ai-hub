# ── LeIsaac 환경변수 (.env.leisaac) ───────────

# Isaac Sim 디스플레이
DISPLAY=:0
ISAAC_HEADLESS=false

# Python 실행 경로 (Isaac Sim 내장 Python)
PYTHON_BIN=/workspace/isaaclab/_isaac_sim/python.sh

# LeIsaac 에셋 루트
LEISAAC_ASSETS_ROOT=eval/leisaac/assets

# Livestream 설정 (0=off, 1=WebSocket, 2=WebRTC)
# 기본 태스크
LEISAAC_TASK=LeIsaac-PiPER-LiftCube-v0

# Livestream 설정 (0=off, 1=WebSocket, 2=WebRTC)
LIVESTREAM_MODE=2
LIVESTREAM_OUT_DIR=/tmp/isaac-livestream
